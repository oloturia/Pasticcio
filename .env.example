# ============================================================
# .env.example — environment variables for development
# ============================================================
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Edit the values you want to change (especially passwords)
#   3. NEVER commit the .env file to Git (it's already in .gitignore)
#      The .env.example file SHOULD be committed — it's just a template.
#
# In production, these variables are set directly on the server
# (or in a secrets manager), not in a file.

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_USER=pasticcio
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=pasticcio_dev
# Full URL used by SQLAlchemy (asyncpg is the async driver)
DATABASE_URL=postgresql+asyncpg://pasticcio:change_this_password_in_production@db:5432/pasticcio_dev

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------
# Secret key for signing JWTs. Must be long and random.
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=replace_with_a_very_long_random_string
# JWT algorithm (do not change)
JWT_ALGORITHM=HS256
# Token expiry in minutes (1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# ----------------------------------------------------------
# Instance settings
# ----------------------------------------------------------
# Public domain of this instance (without https://)
INSTANCE_DOMAIN=pasticcio.localhost
# Display name of the instance
INSTANCE_NAME=Pasticcio Dev
# Short description
INSTANCE_DESCRIPTION=Local development instance
# Contact email of the instance administrator
INSTANCE_CONTACT=admin@example.com

# ----------------------------------------------------------
# Registrations
# ----------------------------------------------------------
# true  → anyone can register
# false → registrations closed (only admin can create accounts)
ENABLE_REGISTRATIONS=true

# ----------------------------------------------------------
# Comments moderation
# ----------------------------------------------------------
# on  → comment moderation
# off → comment not moderated
COMMENTS_MODERATION=off

# ----------------------------------------------------------
# Optional features
# ----------------------------------------------------------
# Enable the nutritional module (FoodItem, kcal calculation, etc.)
ENABLE_NUTRITION=true

# ----------------------------------------------------------
# Storage (images and media)
# ----------------------------------------------------------
# "local" → save to ./media folder (fine for development and Raspberry Pi)
# "s3"    → use an S3-compatible bucket (for larger deployments)
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media

# Uncomment and fill in if using STORAGE_BACKEND=s3
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=pasticcio-media
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_REGION=auto

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------
# "development" → verbose logs, detailed errors, no forced HTTPS
# "production"  → minimal logs, generic errors, HTTPS required
ENVIRONMENT=development
DEBUG=true

# ----------------------------------------------------------
# Rate limit
# ----------------------------------------------------------
# INBOX/API_RATELIMIT_IP_MAX → max requests from the same IP
# INBOX/API_RATELIMIT_IP_WINDOW → the time window in seconds for the IP limit
# INBOX/API_RATELIMIT_DOMAIN_MAX → max requests from the same domain
# INBOX/API_RATELIMIT_DOMAIN_WINDOW → the time window in seconds for the domain limit

INBOX_RATELIMIT_IP_MAX=300
INBOX_RATELIMIT_IP_WINDOW=300
INBOX_RATELIMIT_DOMAIN_MAX=600
INBOX_RATELIMIT_DOMAIN_WINDOW=300
API_RATELIMIT_IP_MAX=60
API_RATELIMIT_IP_WINDOW=60
API_RATELIMIT_USER_MAX=300
API_RATELIMIT_USER_WINDOW=60

# ----------------------------------------------------------
# Mail settings for confirmation
# ----------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Pasticcio
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
